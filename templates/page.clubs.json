        "sxs_RzBtGG": {
          "type": "sxs",
          "settings": {
            "image": "shopify:\/\/shop_images\/playground_club_image.webp",
            "heading_level": "h3",
            "heading_level_display": "",
            "title": "Engage Your Members With Fun Workouts",
            "copy": "<ul><li><strong>Attract & Retain Members<\/strong> – Stand out with unique, high-energy rebounding classes.<\/li><li><strong>Low-Impact, High-Intensity<\/strong> – Offer an effective workout that’s easy on the joints but powerful for cardio, strength, and core training.<\/li><li><strong>Proven Revenue Generator<\/strong> – Premium boutique-style classes increase membership value and drive additional revenue.<\/li><li><strong>Durable, Club-Quality Equipment<\/strong> – Built for daily, high-intensity use with silent, smooth bounce technology.<\/li><\/ul>",
            "btn_url": "shopify:\/\/pages\/jumpsport-fitness-club-studio-locator",
            "btn_copy": ""
          }
        },
        "sxs_fWDite": {
          "type": "sxs",
          "settings": {
            "image": "shopify:\/\/shop_images\/trampoline_trim.webp",
            "heading_level": "h3",
            "heading_level_display": "",
            "title": "Add Variety To Your Schedule",
            "copy": "<p>JumpSport Fitness Trampolines integrate seamlessly into any number of class formats:<\/p><ul><li><strong>Dance & Cardio <\/strong>– Keep members engaged with fun, rhythm-based trampoline workouts.<\/li><li><strong>HIIT & Bootcamp<\/strong> – Amplify calorie burn with high-intensity, low-impact interval training.<\/li><li><strong>Barre & Pilates <\/strong>– Enhance balance, core stability, and flexibility with Pilates or Barre on a rebounder.<\/li><li><strong>Mind-Body Workouts <\/strong>– Incorporate breathwork, meditation, and controlled movement for a holistic fitness experience.<\/li><\/ul><p>With scientifically proven benefits—including improved cardiovascular health, lymphatic drainage, and muscle toning—rebounding is an ideal workout for all fitness levels.<\/p>",
            "btn_url": "",
            "btn_copy": ""
          }
        },
        "sxs_4TXM3L": {
          "type": "sxs",
          "settings": {
            "image": "shopify:\/\/shop_images\/jft-edu-training-course-19a__10797.1555633540.1280.1280.jpg",
            "heading_level": "h2",
            "heading_level_display": "heading--three",
            "title": "Get Premium Bounce Instructor Education",
            "copy": "<p>Equip your instructors with core trampoline competencies and discover new programming.<\/p><ul><li>Design Your Own Trampoline Classes<\/li><li>Hone Teaching Skills<\/li><li>Elevate Your Confidence<\/li><li>Get Feedback From Master Trainers<\/li><li>Earn ACE\/AFAA Credits<\/li><\/ul>",
            "btn_url": "https:\/\/training.jumpsport.com",
            "btn_copy": "View Online Instructor Training Courses"
          }
        }
      },
