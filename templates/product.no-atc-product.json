    "custom_liquid_T9axpe": {
      "type": "custom-liquid",
      "disabled": true,
      "settings": {
        "custom_liquid": "<style>\n  .discount-price {\n    margin-right: 2px;\n  }\n  .original-price {\n    text-decoration: line-through;\n  }\n<\/style>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n  const DISCOUNT_RATE = 0.85;\n\n  if (!document.querySelector('#discount-flag[data-discount=\"true\"]')) return;\n\n  function formatMoney(value) {\n    return `$${parseFloat(value).toFixed(2)}`;\n  }\n\n  function getOriginalPrice() {\n    const selected = document.querySelector('[sm-rc-variant-selector] option:checked');\n    if (!selected) return null;\n\n    let rawPrice = selected.getAttribute('data-compare-price');\n    if (!rawPrice || parseFloat(rawPrice) === 0) {\n      rawPrice = selected.getAttribute('data-price');\n    }\n\n    const price = parseFloat(rawPrice.replace(\/[^0-9.]\/g, ''));\n    return isNaN(price) ? null : price;\n  }\n\n  function updateOrInjectPrice(containerSelector) {\n    const container = document.querySelector(containerSelector);\n    if (!container) return;\n\n    const original = getOriginalPrice();\n    if (!original) return;\n\n    const discounted = original * DISCOUNT_RATE;\n\n    \/\/ If already injected, just update\n    const discountEl = container.querySelector('.discount-price');\n    const originalEl = container.querySelector('.original-price');\n\n    if (discountEl && originalEl) {\n      discountEl.textContent = formatMoney(discounted);\n      originalEl.textContent = formatMoney(original);\n    } else {\n      \/\/ Otherwise inject once\n      container.innerHTML = `\n        <span class=\"discount-price\">${formatMoney(discounted)}<\/span>\n        <span class=\"original-price\">${formatMoney(original)}<\/span>\n      `;\n    }\n  }\n\n  function updateAllPrices() {\n    updateOrInjectPrice('.pdp__price');\n    updateOrInjectPrice('[sm-rc-current-price]');\n  }\n\n  \/\/ Run once\n  setTimeout(updateAllPrices, 400);\n\n  \/\/ Update when variant changes\n  const selector = document.querySelector('[sm-rc-variant-selector]');\n  if (selector) {\n    selector.addEventListener('change', () => {\n      setTimeout(updateAllPrices, 300);\n    });\n  }\n\n  \/\/ Observe dynamic changes\n  const observer = new MutationObserver(() => {\n    setTimeout(updateAllPrices, 300);\n  });\n\n  observer.observe(document.body, { childList: true, subtree: true });\n});\n<\/script>"
      }
    },
