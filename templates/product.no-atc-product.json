    "tab_slider_simple_DfCnPj": {
      "type": "tab-slider-simple",
      "blocks": {
        "slide_ABqXp6": {
          "type": "slide",
          "settings": {
            "tab_title": "Premium Elastic Cords",
            "eyebrow": "",
            "title": "",
            "heading_level": "h3",
            "heading_level_display": "heading--four",
            "copy": "<p><strong>EnduroLast™ Elastic Cords: <\/strong>Experience the pinnacle of performance, unmatched durability, and a smooth, customizable bounce with our EnduroLast Elastic Cords. Stretching up to two times their resting length, these cords feature patented adjustable tension settings and over 50 feet of premium material, ensuring a quiet, cushioned workout that lasts.<\/p><p><strong>Personalize Your Firmness: <\/strong>Our patented connector and knotted cord system allows you to tighten your cords to your preferred firmness setting available on PREMIUM & PRO options only. (<em>4-knot cords shown)<\/em><\/p>",
            "image": "shopify:\/\/shop_images\/adjustable_4_knot_cords.webp",
            "btn_url": "",
            "btn_copy": ""
          }
        },
        "slide_B9RcA3": {
          "type": "slide",
          "settings": {
            "tab_title": "Arched Legs",
            "eyebrow": "",
            "title": "",
            "heading_level": "h3",
            "heading_level_display": "heading--four",
            "copy": "<p><strong>No-tip Safety: <\/strong>Step up with confidence on our patented no-tip arched leg trampolines. <\/p><p><strong>Enhanced Versatility: <\/strong>The stable frame enables a variety of exercises such as push-ups and tricep dips. <\/p><p><strong>Stackable: <\/strong>Arched legs make our trampolines stackable for efficient storage and for box jumps onto a dynamic-surface of any height.<\/p>",
            "image": "shopify:\/\/shop_images\/arched_leg_design_male_box_jump.webp",
            "btn_url": "",
            "btn_copy": ""
          }
        },
        "slide_jwUBkA": {
          "type": "slide",
          "settings": {
            "tab_title": "Lay Flat Mats",
            "eyebrow": "",
            "title": "",
            "heading_level": "h3",
            "heading_level_display": "heading--four",
            "copy": "<p><strong>Exclusive Design: <\/strong>Enhanced jumping mats provide extended usable jumping space with a unique lay-flat design.<\/p><p><strong>Get Creative With More Space: <\/strong>Gain more room for creative choreography and more freedom for taller or heavier bouncers.<\/p><p><strong>Skirt Or Padded Petal Options: <\/strong>Choose a skirt extension or upgrade to padded petals for more comfort when you step or lay on the cords.<\/p>",
            "image": "shopify:\/\/shop_images\/1430_4.jpg",
            "btn_url": "",
            "btn_copy": ""
          }
        },
        "slide_dAKb4M": {
          "type": "slide",
          "settings": {
            "tab_title": "Portability",
            "eyebrow": "",
            "title": "",
            "heading_level": "h3",
            "heading_level_display": "heading--four",
            "copy": "<p><strong>Easy To Move, Easy To Store: <\/strong>With a compact and simple design, you can use it in just about any space and easily move it out of the way when you’re done. <\/p><p><strong>Folding Options Available: <\/strong>39” PREMIUM and 44” PRO trampolines come in a folding option for those who like to workout on-the-go.<\/p>",
            "image": "shopify:\/\/shop_images\/portability_1430x900_c84bb501-9f0c-4261-89e1-b302a43002f8.webp",
            "btn_url": "",
            "btn_copy": ""
          }
        },
        "slide_zw7tNj": {
