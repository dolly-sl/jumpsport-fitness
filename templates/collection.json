    "custom_liquid_cer4Jd": {
      "type": "custom-liquid",
      "disabled": true,
      "settings": {
        "custom_liquid": "<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const discountedHandles = [\n      \"jumpsport-39-pro-fitness-trampoline\",\n\"39-essential-fitness-trampoline\",\n      \"39-premium-fitness-trampoline\"\n    ];\n\n    function applyDiscountToBoostPrices() {\n      const productItems = document.querySelectorAll(\".boost-sd__product-item\");\n\n      productItems.forEach(item => {\n        const dataProductRaw = item.getAttribute(\"data-product\");\n        if (!dataProductRaw) return;\n\n        let productData;\n        try {\n          productData = JSON.parse(dataProductRaw.replace(\/&quot;\/g, '\"'));\n        } catch (e) {\n          console.error(\"Invalid JSON in data-product\", e);\n          return;\n        }\n\n        const handle = productData?.handle;\n        const priceMin = parseFloat(productData?.priceMin);\n\n        if (!handle || !discountedHandles.includes(handle) || isNaN(priceMin)) return;\n\n        const priceSpan = item.querySelector(\".boost-sd__product-price--default .boost-sd__format-currency\");\n        if (!priceSpan || priceSpan.dataset.discountApplied === \"true\") return;\n\n        const discountedPrice = (priceMin * 0.85).toFixed(2);\n\n        \/\/ Create sale price span\n        const salePriceEl = document.createElement(\"span\");\n        salePriceEl.style.marginRight = \"6px\";\n        salePriceEl.style.color = \"black\";\n        salePriceEl.textContent = `$${discountedPrice}`;\n\n        \/\/ Create original price span\n        const originalPriceEl = document.createElement(\"span\");\n        originalPriceEl.style.textDecoration = \"line-through\";\n        originalPriceEl.style.color = \"black\";\n        originalPriceEl.textContent = `$${priceMin.toFixed(2)}`;\n\n        \/\/ Clear and inject new content\n        priceSpan.textContent = \"\";\n        priceSpan.appendChild(salePriceEl);\n        priceSpan.appendChild(originalPriceEl);\n        priceSpan.dataset.discountApplied = \"true\";\n      });\n    }\n\n    \/\/ Initial run after Boost loads products\n    setTimeout(applyDiscountToBoostPrices, 1000);\n\n    \/\/ Observe Boost re-renders\n    const observer = new MutationObserver(applyDiscountToBoostPrices);\n    observer.observe(document.body, { childList: true, subtree: true });\n  });\n<\/script>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const DISCOUNT_HANDLES = [\n      \"jumpsport-39-pro-fitness-trampoline\",\n      \"39-essential-fitness-trampoline\",\n      \"39-premium-fitness-trampoline\"\n    ];\n\n    function applySaleTags() {\n      const products = document.querySelectorAll(\".boost-sd__product-item\");\n\n      products.forEach(product => {\n        const raw = product.getAttribute(\"data-product\");\n        if (!raw) return;\n\n        let parsed;\n        try {\n          parsed = JSON.parse(raw.replace(\/&quot;\/g, '\"'));\n        } catch (e) {\n          console.error(\"Failed to parse product JSON:\", e);\n          return;\n        }\n\n        if (!parsed.handle || !DISCOUNT_HANDLES.includes(parsed.handle)) return;\n\n        \/\/ Avoid duplicate tag\n        const alreadyInjected = product.querySelector('.boost-sd__product-label--sale[data-injected=\"true\"]');\n        if (alreadyInjected) return;\n\n        const labelHTML = `\n          <div class=\"boost-sd__product-label boost-sd__product-label--text boost-sd__product-label--rounded-rectangle boost-sd__product-label--sale\" data-injected=\"true\">\n            <span class=\"boost-sd__product-label-text\"><span>15% Off<\/span><\/span>\n          <\/div>\n        `;\n\n        const target = product.querySelector(\n          \".boost-sd__product-image-column--in-top.boost-sd__product-image-column--left\"\n        );\n\n        if (target) {\n          target.insertAdjacentHTML(\"afterbegin\", labelHTML);\n        }\n      });\n    }\n\n    \/\/ Run on load and observe Boost updates\n    setTimeout(applySaleTags, 1000);\n    const observer = new MutationObserver(applySaleTags);\n    observer.observe(document.body, { childList: true, subtree: true });\n  });\n<\/script>"
      }
    }
  },
