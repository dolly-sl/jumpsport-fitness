      "blocks": {
        "text_FQJJTA": {
          "type": "text",
          "settings": {
            "image": "shopify:\/\/shop_images\/jumpsport-cardio-weightloss-benefits.webp",
            "heading_level": "h3",
            "heading_level_display": "heading--five",
            "title": "Low-Impact Cardio",
            "copy": "<p>Burn calories, elevate your heart rate, and improve endurance — all with less stress on your knees, hips, and ankles than running or plyometric workouts.<\/p>",
            "btn_url": "",
            "btn_copy": ""
          }
        },
        "text_r4WQCg": {
          "type": "text",
          "settings": {
            "image": "shopify:\/\/shop_images\/jumpsport-wellness-recovery-benefits.webp",
            "heading_level": "h3",
            "heading_level_display": "heading--five",
            "title": "Strength & Balance Training",
            "copy": "<p>From squats and lunges to single-leg stability work and athletic drills, the firm-to-extra-firm bounce creates controlled resistance that challenges your muscles and core.<\/p>",
            "btn_url": "",
            "btn_copy": ""
          }
        },
        "text_36VtX7": {
          "type": "text",
          "settings": {
