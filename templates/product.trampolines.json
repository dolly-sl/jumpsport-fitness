        "feature_C8VnaP": {
          "type": "feature",
          "settings": {
            "image": "shopify:\/\/shop_images\/jumpsport-elastic-cords.webp",
            "title": "Premium Elastic Cords",
            "heading_level": "h3",
            "heading_level_display": "heading--five",
            "copy": "Experience the premium bounce that made us famous. Our long-lasting and smooth EnduroLast™ elastic cords are quiet, joint-friendly, and adjustable to fit any intensity.",
            "url": ""
          }
        },
        "feature_qEBYnw": {
          "type": "feature",
          "settings": {
            "image": "shopify:\/\/shop_images\/jumpsport-space.webp",
            "title": "More Space",
            "heading_level": "h3",
            "heading_level_display": "heading--five",
            "copy": "Be free to move more. The durable jumping surface extends over the cords to add protection and additional space for increased creativity.",
            "url": ""
          }
