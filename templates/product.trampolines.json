          "type": "feature",
          "settings": {
            "image": "shopify:\/\/shop_images\/jumpsport-mat.webp",
            "title": "Enhanced Mat",
            "heading_level": "h3",
            "heading_level_display": "heading--five",
            "copy": "Featuring reinforced stitching and enhanced lay-flat mat technology, JumpSport extends your usable space and provides added protection.",
