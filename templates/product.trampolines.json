            "heading_level": "h3",
            "heading_level_display": "heading--five",
            "title": "Recovery & Joint Health",
            "copy": "<p>EnduroLast™ elastic cords provide a cushioned, quiet rebound that absorbs shock and supports joint-friendly movement.<\/p>",
            "btn_url": "",
            "btn_copy": ""
          }
        }
