<nav id="crumbs">
	<div class="container">
		<ul class="list-reset d-flex">
			<li class="d-flex align-center">
				<a href="/">
					Home
				</a>
				<span class="sep">/</span>
			</li>
			<li class="d-flex align-center">
				{% if collection != null %}
					<a href="/collections/{{ collection.handle }}">
						{{ collection.title }}
					</a>
				{% else %}
					<a href="/collections/{{ product.collections[1].handle }}">
						{{ product.collections[1].title }}
					</a>
				{% endif %}
				<span class="sep">/</span>
			</li>
			<li class="current" aria-current="location">
				{{ product.title }}
			</li>

		</ul>
	</div>
</nav>
