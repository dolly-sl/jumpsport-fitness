{% if product.metafields.product.product_tag != blank %}
  <div
    class="card__tag card__tag--pdp tag"
    style="background:{{ product.metafields.product.product_tag.value.tag_color }}"
  >
    <span>
      {{ product.metafields.product.product_tag.value.tag_copy }}
    </span>
  </div>
{% endif %}
<h1 class="heading--three">
  {{ product.title }}
</h1>
<div class="reviews">
  {%- capture sku_list -%}
    {%- for variant  in product.variants -%}
      {{- variant.sku -}},
    {%- endfor -%}
  {%- endcapture -%}
  <!-- TrustBox widget - Product Mini -->
  <div
    class="trustpilot-widget"
    data-locale="en-US"
    data-template-id="577258fb31f02306e4e3aaf9"
    data-businessunit-id="582b8ffe0000ff00059791c8"
    data-style-height="24px"
    data-style-width="100%"
    data-theme="light"
    data-sku="{{ sku_list | strip | append: product.metafields.product.review_skus }}"
    data-no-reviews="show"
    data-font-family="Poppins"
    data-scroll-to-list="true"
    data-style-alignment="left"
  >
    <a href="https://www.trustpilot.com/review/www.jumpsport.com" target="_blank" rel="noopener">Trustpilot</a>
  </div>
  <!-- End TrustBox widget -->
</div>
