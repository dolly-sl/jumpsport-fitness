        }
        renderVariables();

        $('[sm-rc-variant-selector], [sm-rc-plan-selector]').on('change', function () {
          renderVariables();
        });

        $('[sm-rc-add-to-cart]').on('click', function () {
          var qty = 1;

          if ($('.addon.active').length) {
            var prodObject = [];

            $('.addon.active').each(function () {
              var addonVariantID = $(this).attr('data-addon_variant_id');
              prodObject.push({ id: addonVariantID, quantity: '1' });
            });

            prodObject.push({ id: parseInt(currentVariant.id), quantity: qty });

            CartJS.addItems(prodObject, {
              success: function (data, textStatus, jqXHR) {
                //success state
                successState();
                // console.log( 'here-suc' )
              },
              error: function (jqXHR, textStatus, errorThrown) {
                //error state
                console.log('Error: ' + errorThrown + '! - here');
              },
            });
          } else {
            CartJS.addItem(
              parseInt(currentVariant.id),
              qty,
              {},
              {
                success: function (data, textStatus, jqXHR) {
                  //success state
                  successState();
                  // console.log( 'here-suc' )
                },
                error: function (jqXHR, textStatus, errorThrown) {
                  //error state
                  console.log('Error: ' + errorThrown + '! - here');
                },
              }
            );
          }
        });
      });
    })(jQuery);
  </script>
{% endif %}
