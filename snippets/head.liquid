<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
{% if collection.url == '/collections/all' %}
  <meta name="robots" content="noindex,nofollow">
  <script>
    window.location = '/collections/CORRECT COLLECTION HANDLE';
  </script>
{% endif %}
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="theme-color" content="#000005">
{% if page_description != blank %}
  <meta name="description" content="{{ page_description | escape }}">
{% else %}
  <meta
    name="description"
    content="{{ shop.description }}{% if canonical_url contains "tagged" %} Category: {{ current_tags }} {% endif %}"
  >
{% endif %}
<link rel="canonical" href="{{ canonical_url }}">
<link
  rel="shortcut icon"
  href="{{ settings.favicon | img_url: 'master' }}"
  type="image/png"
>

<title>
  {{ page_title -}}
  {%- if current_tags %} | tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} | Page {{ current_page }}{% endif -%}
  {%- unless page_title contains shop.name %} | {{ shop.name }}{% endunless -%}
</title>

{% render 'style-tags', layout: 'theme' %}
{% render 'script-tags', layout: 'theme' %}
