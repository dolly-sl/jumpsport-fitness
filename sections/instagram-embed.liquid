<section
  class="instagram-embed section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="instagram-embed--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container container--xl">
    <div class="instagram-embed__wrap">
      <div class="swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <div class="embed-block">
                <div class="embed-block__embed">
                  {{ block.settings.embed }}
                </div>
                <div class="embed-block__actions text-center">
                  {% render 'dynamic-heading',
                    level: block.settings.heading_level,
                    title: block.settings.title,
                    classList: 'heading--six'
                  %}
                  {% if block.settings.url != blank %}
                    <a href="{{ block.settings.url }}"> Get The Setup </a>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      {% render 'swiper-nav', color: section.settings.background %}
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #instagram-embed--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

<script>
  const embedSlider_{{ section.index }} = new Swiper('#instagram-embed--{{ section.id }} .swiper', {
    slidesPerView: 1,
    direction: 'horizontal',
    spaceBetween: 20,
    centeredSlides: true,
    loop: true,
    navigation: {
      nextEl: '#instagram-embed--{{ section.id }} .swiper__nav .arrow--right',
      prevEl: '#instagram-embed--{{ section.id }} .swiper__nav .arrow--left',
    },
    breakpoints: {
      992: {
        slidesPerView: 3,
        centeredSlides: false,
      },
      1300: {
        slidesPerView: 3,
        centeredSlides: false,
      },
    },
  });
</script>

