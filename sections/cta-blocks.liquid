<section
  class="cta-blocks section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="cta-blocks--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container">
    {% if section.settings.title != blank %}
      <div class="cta-blocks__heading d-flex justify-center text-center">
        {% render 'dynamic-heading',
          level: section.settings.heading_level,
          title: section.settings.title,
          classList: section.settings.heading_level_display
        %}
      </div>
    {% endif %}
    <div class="cta-blocks__inner d-flex justify-between">
      {% for block in section.blocks %}
        <a href="{{ block.settings.url }}" class="cta-block d-block">
          <div class="cta-block__image">
            <img
              src="{{ block.settings.image | img_url: '590x400' }}"
              srcset="{{ block.settings.image | img_url: '1180x800' }} 2x"
              alt="{{ block.settings.image.alt | escape }}"
            >
          </div>
          {% render 'dynamic-heading',
            level: block.settings.heading_level,
            title: block.settings.title,
            classList: block.settings.heading_level_display,
            internal: 'span',
            alt: block.settings.title_alt
          %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #cta-blocks--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

