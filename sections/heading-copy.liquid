<section
  class="heading-copy section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="heading-copy--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container container--md">
    <div class="heading-copy__inner  align--{{ section.settings.copy_align }}">
      {% if section.settings.eyebrow != blank %}
        <span class="eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}
      {% if section.settings.title != blank %}
        {% render 'dynamic-heading',
          level: section.settings.heading_level,
          title: section.settings.title,
          classList: section.settings.heading_level_display
        %}
      {% endif %}

      {% if section.settings.copy != blank or section.settings.liquid != blank %}
        <div class="copy">
          {{ section.settings.copy }}
          {{ section.settings.liquid }}
        </div>
      {% endif %}
      {% if section.settings.btn_url != blank and section.settings.btn_copy != blank %}
        <div class="actions d-flex justify-center">
          <a href="{{ section.settings.btn_url }}" class="btn btn--solid btn--arrow btn--xl">
            {{ section.settings.btn_copy }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] != blank or section.settings['padding_top-mobile'] != blank %}
  <style>
    @media(max-width: 768px) {
      #heading-copy--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

