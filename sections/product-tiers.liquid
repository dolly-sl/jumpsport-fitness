<section
  class="product-tiers section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="product-tiers--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container container--md">
    <div class="product-tiers__list d-flex justify-center">
      {% for block in section.blocks %}
        <div class="tier" {{ block.shopify_attributes }}>
          <div class="tier__inner text-center">
            <div class="tier__heading" style="background: {{ block.settings.color }}">
              <span class="eyebrow">
                {{ block.settings.eyebrow }}
              </span>
              {% render 'dynamic-heading',
                level: block.settings.heading_level,
                title: block.settings.title,
                classList: block.settings.heading_level_display
              %}
              <span class="sub">
                {{ block.settings.sub_title }}
              </span>
            </div>
            <div class="tier__info">
              {{ block.settings.copy }}
              {% if block.settings.btn_url != blank %}
                <div class="actions d-flex justify-center">
                  <a href="{{ block.settings.btn_url }}" class="btn btn--solid btn--arrow btn--xl">
                    {{ block.settings.btn_copy }}
                  </a>
                </div>
              {% endif %}
              <p class="disclaimer">
                {{ block.settings.disclaimer }}
              </p>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #product-tiers--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}
