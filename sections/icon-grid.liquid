<section
  class="icon-grid section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="icon-grid--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container d-flex justify-center">
    {% for block in section.blocks %}
      <div class="icon-grid__icon text-center">
        <img
          loading="lazy"
          src="{{ block.settings.icon | img_url: '70x70' }}"
          srcset="{{ block.settings.icon | img_url: '140x140' }}"
          alt=""
        >
        <span class="eyebrow">
          {{ block.settings.title }}
        </span>
      </div>
    {% endfor %}
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #icon-grid--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}
