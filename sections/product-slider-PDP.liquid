{% comment %}
  <div id="recommended-products">
    <h2>You may also like</h2>
    <div class="products-list"></div>
  </div>

  <script>
    $(document).ready(function () {
      let productId = '{{ product.id }}'; // Get current product ID in Liquid

      $.ajax({
        url: `/recommendations/products.json?product_id=${productId}&limit=24`,
        method: 'GET',
        dataType: 'json',
        success: function (data) {
          if (data.products.length > 0) {
            let productHtml = '';
            data.products.forEach((product) => {
              productHtml += `
                <div class="recommended-product">
                  <a href="${product.url}">
                    <img src="${product.featured_image}" alt="${product.title}" width="150">
                    <p>${product.title}</p>
                    <p>${product.price}</p>
                  </a>
                </div>
              `;
            });
            $('.products-list').html(productHtml);
          } else {
            $('#recommended-products').hide();
          }
        },
        error: function () {
          console.log('Error fetching recommended products.');
        },
      });
    });
  </script>
{% endcomment %}

{% if section.settings.product_list != empty %}
  <section
    class="product-slider product-slider--pdp section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
    id="product-slider--{{ section.id }}"
  >
    {% render 'arch', color: section.settings.background %}
    <div class="container">
      <div class="product-slider__heading d-flex align-center justify-between">
        <{{ section.settings.heading_level }} class="scheme-color">
          {{ section.settings.title }}
        </{{ section.settings.heading_level }}>
        <div class="actions">
          {% if section.settings.btn_url != blank and section.settings.btn_copy != blank %}
            <a href="{{ section.settings.btn_url }}" class="btn btn--solid btn--arrow">
              {{ section.settings.btn_copy }}
            </a>
          {% endif %}
        </div>
      </div>
      <div class="product-slider__slider swiper">
        <div class="swiper-wrapper">
          {% for prodObject in section.settings.product_list %}
            <div class="swiper-slide">
              {% render 'product-card-full', data: prodObject %}
            </div>
          {% endfor %}
        </div>
      </div>
      {% render 'swiper-nav', color: section.settings.background %}
    </div>
  </section>

  <script>
    const productSlider_{{ section.index }} = new Swiper('#product-slider--{{ section.id }} .swiper', {
      slidesPerView: 'auto',
      spaceBetween: 20,
      centeredSlides: true,
      loop: true,
      navigation: {
        nextEl: '#product-slider--{{ section.id }} .swiper__nav .arrow--right',
        prevEl: '#product-slider--{{ section.id }} .swiper__nav .arrow--left',
      },
      breakpoints: {
        768: {
          slidesPerView: 4,
          centeredSlides: false,
        },
      },
    });
  </script>
{% endif %}

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #product-slider--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

