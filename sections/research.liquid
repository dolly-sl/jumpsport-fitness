<section
  class="research section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="research--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container container--sm">
    {% if section.settings.title != blank or section.settings.copy != blank or section.settings.btn_url != blank %}
      <div class="research__heading text-center">
        {% if section.settings.title != blank %}
          {% render 'dynamic-heading',
            level: section.settings.heading_level,
            title: section.settings.title,
            classList: section.settings.heading_level_display
          %}
        {% endif %}
        <div class="copy scheme-color">
          {{ section.settings.copy }}
        </div>
        {% if section.settings.btn_url != blank and section.settings.btn_copy != blank %}
          <div class="actions d-flex justify-center">
            <a href="{{ section.settings.btn_url }}" class="btn btn--white btn--arrow btn--xl">
              {{ section.settings.btn_copy }}
            </a>
          </div>
        {% endif %}
      </div>
    {% endif %}
    {% if section.settings.col_1_title != blank or section.settings.col_2_title != blank %}
      <div class="research__results">
        <div class="table-wrap scheme-color">
          <div class="thead d-flex justify-between">
            <div class="th th--blank"></div>
            <div class="th th--jumpsport">
              {{ section.settings.col_1_title }}
            </div>
            <div class="th">
              {{ section.settings.col_2_title }}
            </div>
            {% comment %}
              <div class="th">
                <span>{{ section.settings.col_3_head }}</span>
              </div>
            {% endcomment %}
          </div>
          <div class="tbody">
            {% for block in section.blocks %}
              {% if block.type == 'row' %}
                <div class="tr d-flex justify-between">
                  <div class="td td--label">
                    <span>
                      {{ block.settings.title }}
                    </span>
                  </div>
                  <div class="td td--jumpsport">
                    <span class="mobile-label">
                      {{ block.settings.title }}
                    </span>
                    {{ block.settings.jumpsport }}
                  </div>

                  <div class="td">
                    <span class="mobile-label">
                      {{ block.settings.title }}
                    </span>
                    {{ block.settings.treadmill }}
                    {% if block.settings.treadmill_check == true %}
                      <span class="check check--mobile">
                        <span>&#10003;</span>
                      </span>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            {% endfor %}
            <div class="tr d-flex justify-between">
              <div class="td td--label"></div>
              <div class="td td--jumpsport"></div>
              <div class="td"></div>
            </div>
          </div>
        </div>
        <div class="disclaimer text-center scheme-color">
          {{ section.settings.disclaimer }}
        </div>
      </div>
    {% endif %}
    <div class="research__studies">
      {% if section.settings.studies_title != blank %}
        <h2 class="text-center scheme-color heading--four">
          {{ section.settings.studies_title }}
        </h2>
      {% endif %}
      <ol class="list">
        {% for block in section.blocks %}
          {% if block.type == 'study' %}
            <li class="scheme-color">
              {{ block.settings.title }}
            </li>
          {% endif %}
        {% endfor %}
      </ol>
      {% comment %}
        {% if section.blocks.size > 3 %}
          <div class="more">
            <a href="#" class="link"> View More </a>
          </div>
          <div class="hidden-study">
            <ol class="list">
              {% for block in section.blocks offset: 3 %}
                {% if block.type == 'study' %}
                  <li class="scheme-color">
                    {{ block.settings.title }}
                  </li>
                {% endif %}
              {% endfor %}
            </ol>
          </div>
        {% endif %}
      {% endcomment %}
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #research--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

<script>
  jQuery(document).ready(function ($) {
    $('#research--{{ section.id }} .more a').on('click', function (e) {
      e.preventDefault();
      $('#research--{{ section.id }} .hidden-study').slideToggle();
    });
  });
</script>

