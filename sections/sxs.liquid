<section
  class="sxs section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="heading-block--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container {% if section.settings.width == true %}container--sm{% else %}container--md{% endif %}">
    {% for block in section.blocks %}
      <div
        class="sxs__block {% unless section.settings.width == true %} sxs__block--lg{% endunless %} d-flex align-center justify-between{% if section.settings.width == 1 %} sxs__block--sm{% endif %}"
        {{ block.shopify_attributes }}
      >
        <div class="sxs__image">
          <img
            loading="lazy"
            src="{{ block.settings.image | img_url: '470x470' }}"
            srcset="{{ block.settings.image | img_url: '940x940' }} 2x"
            alt="{{ block.settings.image.alt | escape }}"
          >
        </div>
        <div class="sxs__info">
          {% render 'dynamic-heading',
            level: block.settings.heading_level,
            title: block.settings.title,
            classList: block.settings.heading_level_display
          %}
          {{ block.settings.copy }}
          {% if block.settings.btn_url != blank and block.settings.btn_copy != blank %}
            <div class="actions">
              <a href="{{ block.settings.btn_url }}" class="btn btn--solid">
                {{ block.settings.btn_copy }}
              </a>
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #sxs--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

