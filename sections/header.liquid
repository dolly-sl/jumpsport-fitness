<header class="header">
  <div class="container container--xl">
    <div class="header__inner d-flex align-center justify-between">
      <div class="header__mobile-only">
        <div class="inner d-flex align-center">
          <div class="header__mobile-trigger">
            <button class="hamburger hamburger--collapse" type="button">
              <span class="sr-only">Mobile Menu</span>
              <span class="hamburger-box">
                <span class="hamburger-inner"></span>
              </span>
            </button>
          </div>
          <button class="icon icon--search">
            <span class="sr-only">Search</span>
            <img src="{{ 'icon-search.svg' | asset_url }}" alt="">
          </button>
        </div>
      </div>

      <div class="header__logo">
        <a href="/">
          <img
            class="logo logo--full"
            src="{{ 'logo-full.svg' | asset_url }}"
            alt="Jumpsport Fitness Logo"
          >
          <img
            class="logo logo--mark"
            src="{{ 'logo-mark.svg' | asset_url }}"
            alt="Jumpsport Fitness Logo Mark"
          >
        </a>
      </div>

      {% render 'header-nav', nav: section.settings.menu_main %}

      <div class="header__icons d-flex justify-between">
        <a href="/account" class="icon icon--account">
          <span class="sr-only">Account</span>
          <img src="{{ 'icon-account.svg' | asset_url }}" alt="">
        </a>
        <div class="icon-relative">
          <button class="icon icon--globe">
            <span class="sr-only">International Markets</span>
            <img src="{{ 'icon-globe.svg' | asset_url }}" alt="">
          </button>
          {% render 'country-select' %}
        </div>

        <button class="icon icon--search">
          <span class="sr-only">Search</span>
          <img src="{{ 'icon-search.svg' | asset_url }}" alt="">
        </button>
        <button class="icon icon--cart">
          <span
            class="cart-count"
            {% if cart.item_count == 0 %}
              style="display:none"
            {% endif %}
          >
            <span>{{ cart.item_count }}</span>
          </span>
          <span class="sr-only">Cart</span>
          <img src="{{ 'icon-cart.svg' | asset_url }}" alt="">
        </button>
      </div>
    </div>
  </div>
  <div class="header__bg"></div>
  {% render 'mobile-menu', nav: section.settings.menu_main %}
</header>
{% render 'desktop-search' %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "id": "menu_main",
