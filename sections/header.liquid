      "settings": [
        {
          "id": "top_level_nav",
          "type": "text",
          "label": "Top Level Nav Item"
        },
        {
          "id": "menu_title",
          "type": "text",
          "label": "Menu Title"
        },
        {
          "id": "menu",
          "type": "link_list",
          "label": "Menu"
        },
        {
          "id": "menu_image",
          "type": "image_picker",
