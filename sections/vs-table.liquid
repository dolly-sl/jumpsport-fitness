<section
  class="vs-table section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="vs-table--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container">
    <div class="vs-table__heading d-flex">
      <div class="col col--label"></div>
      <div class="col col--js text-center">
        <img
          loading="lazy"
          src="{{ section.settings.image_col_1 | img_url: '350x350' }}"
          srcset="{{ section.settings.image_col_1 | img_url: '700x700' }} 2x"
          alt="{{ section.settings.image_col_1.alt | escape }}"
        >

        {% render 'dynamic-heading',
          level: section.settings.heading_level,
          title: section.settings.title_col_1,
          classList: section.settings.heading_level_display
        %}
      </div>
      <div class="col col--other text-center">
        <img
          loading="lazy"
          src="{{ section.settings.image_col_2 | img_url: '350x350' }}"
          srcset="{{ section.settings.image_col_2 | img_url: '700x700' }} 2x"
          alt="{{ section.settings.image_col_1.alt | escape }}"
        >
        {% render 'dynamic-heading',
          level: section.settings.heading_level,
          title: section.settings.title_col_2,
          classList: section.settings.heading_level_display
        %}
      </div>
    </div>
    <div class="vs-table__table">
      {% for block in section.blocks %}
        <div class="row d-flex align-center">
          <div class="col col--label">
            {%
              render 'dynamic-heading',
              level: block.settings.heading_level,
              title: block.settings.title,
              classList: block.settings.heading_level_display | append: ' label'
            %}
          </div>
          <div class="col col--js">
            <h4 class="label label--mobile scheme-color">
              {{ block.settings.title }}
            </h4>
            {{ block.settings.val_js }}
          </div>
          <div class="col col--other">
            {% render 'dynamic-heading',
              level: block.settings.heading_level,
              title: block.settings.title,
              classList: 'heading--four label label--mobile'
            %}
            {{ block.settings.val_other }}
          </div>
        </div>
      {% endfor %}
    </div>
    {% if section.settings.btn_url != blank or section.settings.disclaimer != blank %}
      <div class="actions text-center d-flex justify-center">
        {% if section.settings.btn_url != blank %}
          <a href="{{ section.settings.btn_url }}" class="btn btn--solid">
            {{ section.settings.btn_copy }}
          </a>
        {% endif %}
        {% if section.settings.disclaimer != blank %}
          <div class="disclaimer">
            {{ section.settings.disclaimer }}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #vs-table--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

