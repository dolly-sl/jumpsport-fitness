<section
  class="quote-slider section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="quote-slider--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  {% unless section.settings.hide_bg == true %}
    <img src="{{ 'pattern-bg.png' | asset_img_url: 'master' }}" alt="" class="quote-slider__bg">
  {% endunless %}
  <div class="container">
    <div class="quote-slider__slider swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="inner text-center">
              <span class="eyebrow scheme-color">
                {{ section.settings.eyebrow }}
              </span>
              {% render 'dynamic-heading',
                level: block.settings.heading_level,
                title: block.settings.quote,
                classList: block.settings.heading_level_display
              %}
              <p class="author scheme-color">- {{ block.settings.author }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  const quoteSlider = new Swiper('#quote-slider--{{ section.id }} .swiper', {
    slidesPerView: 1,
    loop: true,
    effect: 'fade',
    fadeEffect: { crossFade: true },
    autoplay: true,
  });
</script>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #quote-slider--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

