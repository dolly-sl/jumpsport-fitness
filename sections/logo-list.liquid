<section
  class="logo-list section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }}  background--{{ section.settings.background }} {% if section.settings.hide_line == true %}hide-line{% endif %}"
  id="logo-list--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container">
    {% if section.settings.title != blank %}
      {% render 'dynamic-heading',
        level: section.settings.heading_level,
        title: section.settings.title,
        classList: 'eyebrow text-center'
      %}
    {% endif %}
    <div class="logo-list__wrap d-flex justify-center">
      {% for block in section.blocks %}
        <div class="logo" {{ block.shopify_attributes }}>
          {% if block.settings.url != blank %}
            <a href="{{ block.settings.url }}">
          {% endif %}
          <img
            loading="lazy"
            src="{{ block.settings.logo | img_url: '200x' }}"
            srcset="{{ block.settings.logo | img_url: '400x' }} 2x"
            alt=""
          >
          {% if block.settings.url != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #logo-list--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

