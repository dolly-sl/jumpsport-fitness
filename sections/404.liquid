<section
  class="page page--404 pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
>
  <div class="container  text-center">
    <div class="error__inner">
      <div class="page__heading">
        {% if section.settings.eyebrow != blank %}
          <span class="eyebrow">
            {{ section.settings.eyebrow }}
          </span>
        {% endif %}
        <h1>
          {{ section.settings.heading }}
        </h1>
      </div>
      <div class="page__content">
        {{ section.settings.copy }}

        {% if section.settings.btn_url != blank %}
          <div class="actions d-flex justify-center">
            <a href="{{ section.settings.btn_url }}" class="btn btn--solid btn--arrow btn--xl">
              {{ section.settings.btn_copy }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      .page--404 {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

