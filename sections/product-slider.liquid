<section
  class="product-slider section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="product-slider--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container">
    <div class="product-slider__heading d-flex align-center justify-between">
      {% if section.settings.title != blank %}
        {% render 'dynamic-heading',
          level: section.settings.heading_level,
          title: section.settings.title,
          classList: section.settings.heading_level_display
        %}
      {% endif %}
      <div class="actions">
        {% if section.settings.btn_url != blank and section.settings.btn_copy != blank %}
          <a href="{{ section.settings.btn_url }}" class="btn btn--solid btn--arrow">
            {{ section.settings.btn_copy }}
          </a>
        {% endif %}
      </div>
    </div>
    <div class="product-slider__slider swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            {% render 'product-card-full', data: block.settings.product %}
          </div>
        {% endfor %}
      </div>
    </div>
    {% if section.blocks.size > 4 %}
      {% render 'swiper-nav', color: section.settings.background %}
    {% endif %}
  </div>
</section>

<script>
  const productSlider_{{ section.index }} = new Swiper('#product-slider--{{ section.id }} .swiper', {
    slidesPerView: 'auto',
    spaceBetween: 20,
    centeredSlides: true,
    loop: true,
    navigation: {
      nextEl: '#product-slider--{{ section.id }} .swiper__nav .arrow--right',
      prevEl: '#product-slider--{{ section.id }} .swiper__nav .arrow--left',
    },
    breakpoints: {
      768: {
        slidesPerView: 4,
        centeredSlides: false,
      },
    },
  });
</script>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #product-slider--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

