<section
  class="accordions section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="accordions--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container container--sm">
    <div class="accordions__heading d-flex align-center justify-between">
      {% if section.settings.title != blank %}
        {% render 'dynamic-heading',
          level: section.settings.heading_level,
          title: section.settings.title,
          classList: section.settings.heading_level_display
        %}
      {% endif %}
      <div class="actions">
        {% if section.settings.btn_url != blank and section.settings.btn_copy != blank %}
          <a href="{{ section.settings.btn_url }}" class="btn btn--solid btn--arrow">
            {{ section.settings.btn_copy }}
          </a>
        {% endif %}
      </div>
    </div>
    <div class="accordions__list">
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }} class="accordion__group ">
          <button class="accordion__heading" data-image="image-{{forloop.index}}">
            {%- render 'dynamic-heading',
              level: block.settings.heading_level,
              title: block.settings.title,
              classList: block.settings.heading_level_display,
              internal: ''
            -%}
          </button>
          <div
            class="accordion__copy"
          >
            {{ block.settings.copy }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #accordions--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

