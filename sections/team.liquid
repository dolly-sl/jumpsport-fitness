<section
  class="team section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="team--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container d-flex justify-between">
    <div class="team__heading">
      {% if section.settings.title != blank %}
        {% render 'dynamic-heading',
          level: section.settings.heading_level,
          title: section.settings.title,
          classList: section.settings.heading_level_display
        %}
      {% endif %}
      {{ section.settings.copy }}
    </div>
    <div class="team__list team__list--desktop d-flex">
      {% for block in section.blocks %}
        <a
          href="#"
          data-modal="{{ block.settings.title | handleize }}--{{ forloop.index }}"
          class="team-member d-block btn--modal"
        >
          <div class="team-member__image">
            <img
              loading="lazy"
              src="{{ block.settings.image | img_url: '265x465', crop:center }}"
              srcset="{{ block.settings.image | img_url: '530x930', crop:center }} 2x"
              alt="{{ block.settings.image.alt | escape }}"
              class="image image--main"
            >
            {% if block.settings.image_hover != blank %}
              <img
                loading="lazy"
                src="{{ block.settings.image_hover | img_url: '265x465', crop:center }}"
                srcset="{{ block.settings.image_hover | img_url: '530x930', crop:center }} 2x"
                alt="{{ block.settings.image_hover.alt | escape }}"
                class="image image--hover"
              >
            {% endif %}
          </div>
          <div class="team-member__info">
            {% render 'dynamic-heading',
              level: block.settings.heading_level,
              title: block.settings.title,
              classList: block.settings.heading_level_display
            %}
            <span class="subtitle">
              {{ block.settings.sub_title }}
            </span>
            <span class="link scheme-color"> View Bio </span>
          </div>
        </a>
      {% endfor %}
    </div>
    <div class="team__list team__list--mobile ">
      <div class="swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide">
              <a
                href="#"
                data-modal="{{ block.settings.title | handleize }}--{{ forloop.index }}"
                class="team-member d-block btn--modal"
              >
                <div class="team-member__image">
                  <img
                    loading="lazy"
                    src="{{ block.settings.image | img_url: '265x465', crop:center }}"
                    srcset="{{ block.settings.image | img_url: '530x930', crop:center }} 2x"
                    alt="{{ block.settings.image.alt | escape }}"
                    class="image image--main"
                  >
                  {% if block.settings.image_hover != blank %}
                    <img
                      loading="lazy"
                      src="{{ block.settings.image_hover | img_url: '265x465', crop:center }}"
                      srcset="{{ block.settings.image_hover | img_url: '530x930', crop:center }} 2x"
                      alt="{{ block.settings.image_hover.alt | escape }}"
                      class="image image--hover"
                    >
                  {% endif %}
                </div>
                <div class="team-member__info">
                  <h3 class="heading--four scheme-color">
                    {{ block.settings.title }}
                  </h3>
                  <span class="subtitle">
                    {{ block.settings.sub_title }}
                  </span>
                  <span class="link scheme-color"> View Bio </span>
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
      {% render 'swiper-nav', color: section.settings.background %}
    </div>
  </div>
</section>
{% for block in section.blocks %}
  <div class="modal modal--instructor" id="{{ block.settings.title | handleize }}--{{ forloop.index }}">
    <div class="modal__bg"></div>
    <div class="modal__wrap">
      <div class="modal__inner">
        <button class="modal--close">
          <span class="sr-only">Close Modal</span>
          <img src="{{ 'icon-close.svg' | asset_url }}" alt="">
        </button>
        <div class="instructor-block d-flex justify-between">
          <div class="instructor-block__image">
            <img
              src="{{ block.settings.image | img_url: '265x465', crop:center }}"
              srcset="{{ block.settings.image | img_url: '530x930', crop:center }} 2x"
              alt="{{ block.settings.image.alt | escape }}"
              class="image image--main"
            >
          </div>
          <div class="instructor-block__info">
            <h2 class="heading--three">
              {{ block.settings.title }}
            </h2>
            <span class="subtitle">
              {{ block.settings.sub_title }}
            </span>
            <div class="copy">
              {{ block.settings.copy }}
            </div>
            {% if block.settings.url != blank %}
              <a href="{{ block.settings.url }}" class="link"> View Profile </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endfor %}

<script>
  const productSlider = new Swiper('#team--{{ section.id }} .swiper', {
    slidesPerView: 'auto',
    spaceBetween: 20,
    centeredSlides: true,
    loop: true,
    navigation: {
      nextEl: '#team--{{ section.id }} .swiper__nav .arrow--right',
      prevEl: '#team--{{ section.id }} .swiper__nav .arrow--left',
    },
  });
</script>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #team--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

