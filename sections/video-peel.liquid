<section
  class="video-peel section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="video-peel--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container">
    <div class="video-peel__heading d-flex justify-center">
      {% if section.settings.title != blank %}
        {% render 'dynamic-heading',
          level: section.settings.heading_level,
          title: section.settings.title,
          classList: section.settings.heading_level_display
        %}
      {% endif %}
      {% if section.settings.btn_url != blank and section.settings.btn_copy != blank %}
        <div class="actions">
          <a href="{{ section.settings.btn_url }}" class="btn btn--solid btn--arrow btn--xl">
            {{ section.settings.btn_copy }}
          </a>
        </div>
      {% endif %}
    </div>
    <div class="video-peel__slider">
      <script type="text/javascript" async src="https://plugin.videopeel.com/v2/current/injectWidget.js"></script>
      {{ section.settings.embed }}
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #video-peel--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

<script>
  jQuery(document).ready(function ($) {
    $('#video-peel--{{ section.id }} iframe').attr('title', 'Social Reviews');
  });
</script>

