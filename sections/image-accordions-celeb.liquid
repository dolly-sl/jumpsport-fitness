<section
  id="image-accordions--{{ section.id }}"
  class="image-accordions image-accordions--celeb section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container d-flex justify-between align-center align--{{ section.settings.align }}">
    <div class="image-accordions__content">
      <div class="info">
        <div class="upper d-flex align-center justify-between">
          <img
            loading="lazy"
            src="{{ section.settings.image | img_url: '100x100' }}"
            srcset="{{ section.settings.image | img_url: '200x200' }} 2x"
            alt="{{ section.settings.image.alt | escape }}"
          >
          {% render 'dynamic-heading',
            level: section.settings.heading_level,
            title: section.settings.title,
            classList: section.settings.heading_level_display
          %}
        </div>
        {{ section.settings.copy }}
      </div>
      <div class="acc__wrap">
        {% for block in section.blocks %}
          <div {{ block.shopify_attributes }} class="accordion__group">
            <button class="accordion__heading" data-image="image-{{forloop.index}}">
              {% render 'dynamic-heading',
                level: block.settings.heading_level,
                title: block.settings.title,
                classList: block.settings.heading_level_display
              %}
            </button>
            <div class="accordion__copy">
              {{ block.settings.copy }}
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.btn_url != blank and section.settings.btn_copy != blank %}
        <div class="actions">
          <a href="{{ section.settings.btn_url }}" class="btn btn--solid">
            {{ section.settings.btn_copy }}
          </a>
        </div>
      {% endif %}
    </div>
    <div class="image-accordions__images">
      <img
        loading="lazy"
        src="{{ section.settings.image_lg | img_url: '700x' }}"
        srcset="{{ section.settings.image_lg | img_url: '1400x' }} 2x"
        alt="{{ section.settings.image_lg.alt | escape }}"
      >
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #image-accordions--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

