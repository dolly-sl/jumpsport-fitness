<section
  class="image-grid image-grid--overflow section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }}  background--{{ section.settings.background }}"
  id="image-grid--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container">
    <div class="image-grid__heading d-flex align-center justify-between">
      {% render 'dynamic-heading',
        level: section.settings.heading_level,
        title: section.settings.title,
        classList: section.settings.heading_level_display
      %}
      <div class="actions">
        {% if section.settings.btn_url != blank and section.settings.btn_copy != blank %}
          <a href="{{ section.settings.btn_url }}" class="btn btn--solid btn--arrow">
            {{ section.settings.btn_copy }}
          </a>
        {% endif %}
      </div>
    </div>
    <div class="arrow-wrap">
      <div class="image-grid__list swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <div class="image-block">
                {% if block.settings.url != blank %}
                  <a href="{{ block.settings.url }}">
                {% endif %}
                {% unless block.settings.video != blank %}
                  <img
                    loading="lazy"
                    src="{{ block.settings.image | img_url: '250x250', crop: center }}"
                    srcset="{{ block.settings.image | img_url: '500x500', crop: center }} 2x"
                    alt=""
                  >
                {% endunless %}
                {% if block.settings.video != blank %}
                  {{
                    block.settings.video
                    | video_tag: autoplay: false, loop: false, muted: true, controls: true, image_size: '430x750'
                  }}
                {% endif %}
                {% if block.settings.title != blank %}
                  {% render 'dynamic-heading',
                    level: block.settings.heading_level,
                    title: block.settings.title,
                    classList: block.settings.heading_level_display
                  %}
                {% endif %}
                {% if block.settings.url != blank %}
                  </a>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      {% render 'swiper-nav', color: section.settings.background %}
    </div>
  </div>
</section>

<script>
  const imageGridSlider = new Swiper('#image-grid--{{ section.id }} .swiper', {
    slidesPerView: 'auto',
    spaceBetween: 20,
    centeredSlides: true,
    loop: true,
    navigation: {
      nextEl: '#image-grid--{{ section.id }} .swiper__nav .arrow--right',
      prevEl: '#image-grid--{{ section.id }} .swiper__nav .arrow--left',
    },
  });
</script>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #image-grid--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

