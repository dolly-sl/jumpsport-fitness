<section
  class="tab-slider tab-slider--simple section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="tab-slider_simple--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container">
    <div class="tab-slider__heading d-flex justify-center">
      <div class="copy text-center">
        {% if section.settings.title != blank %}
          {% render 'dynamic-heading',
            level: section.settings.heading_level,
            title: section.settings.title,
            classList: section.settings.heading_level_display
          %}
        {% endif %}
        <div class="tabs tabs--desktop d-flex justify-center">
          {% for block in section.blocks %}
            <button
              class="tab scheme-color {% if forloop.first == true %}active{%endif%}"
              data-index="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.tab_title }}
            </button>
          {% endfor %}
        </div>
        <div class="tabs tabs--slider d-flex justify-center">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                <span class="scheme-color tab">
                  {{ block.settings.tab_title }}
                </span>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    <div class="tab-slider__slider tab-slider__slider--simple swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="inner d-flex justify-between align-center">
              <div class="slide__content">
                {% if block.settings.eyebrow != blank %}
                  <span class="eyebrow scheme-color">
                    {{ block.settings.eyebrow }}
                  </span>
                {% endif %}
                {% if block.settings.image_eyebrow != blank %}
                  <img
                    src="{{ block.settings.image_eyebrow | img_url: 'master' }}"
                    alt="{{ block.settings.image_eyebrow.alt | escape }}"
                    class="eye-logo"
                  >
                {% endif %}
                {% if block.settings.title != blank and block.settings.title != '' %}
                  {% render 'dynamic-heading',
                    level: block.settings.heading_level,
                    title: block.settings.title,
                    classList: block.settings.heading_level_display
                  %}
                {% endif %}
                <div class="scheme-color">
                  {{ block.settings.copy }}
                </div>
                {% if block.settings.btn_url != blank %}
                  <div class="actions">
                    <a href="{{ block.settings.btn_url }}" class="btn btn--solid btn--arrow btn--xl">
                      {{ block.settings.btn_copy }}
                    </a>
                  </div>
                {% endif %}
              </div>
              <div class="slide__image">
                {% if block.settings.image != blank %}
                  <img
                    loading="lazy"
                    src="{{ block.settings.image | img_url: '715x450' }}"
                    srcset="{{ block.settings.image | img_url: '1430x900' }} 2x"
                    alt="{{  block.settings.image.alt | escape }}"
                  >
                {% endif %}
                {% if block.settings.video != blank %}
                  {{
                    block.settings.video
                    | video_tag: autoplay: false, loop: true, muted: false, controls: true, image_size: '715x450'
                  }}
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
      {% render 'swiper-nav', color: 'white' %}
    </div>
  </div>
</section>

<script>
  jQuery(document).ready(function () {
    const tabSlider = new Swiper('#tab-slider_simple--{{ section.id }} .swiper', {
      slidesPerView: 1,
      loop: true,
      effect: 'fade',
      fadeEffect: { crossFade: true },
      navigation: {
        nextEl: '#tab-slider_simple--{{ section.id }} .swiper__nav .arrow--right',
        prevEl: '#tab-slider_simple--{{ section.id }} .swiper__nav .arrow--left',
      },
    });

    const tabsSlider = new Swiper('#tab-slider_simple--{{ section.id }} .tabs--slider', {
      slidesPerView: 2,
      spaceBetween: 0,
      centeredSlides: true,
      loop: false,
      watchSlidesProgress: true,
      slideToClickedSlide: true,
      breakpoints: {
        // when window width is >= 320px
        // when window width is >= 640px
        568: {
          slidesPerView: 3,
          spaceBetween: 0,
        },
        768: {
          slidesPerView: 4,
          spaceBetween: 0,
        },
      },
      {% comment %} thumbs: {
        swiper: tabSlider,
      }, {% endcomment %}
    });

    tabsSlider.controller.control = tabSlider;
    tabSlider.controller.control = tabsSlider;

    // Change slide, activate tab
    tabSlider.on('transitionEnd', function () {
      $('#tab-slider_simple--{{ section.id }} .tabs--desktop .tab').removeClass('active');
      $('#tab-slider_simple--{{ section.id }} .tabs--desktop  .tab[data-index="' + tabSlider.realIndex + '"]').addClass('active');
    });

    // Click tab, go to slide
    $('#tab-slider_simple--{{ section.id }} .tabs--desktop .tab').on('click', function () {
      console.log('outside');
      if (!$(this).hasClass('active')) {
        console.log('inside');
        const slideIndex = $(this).attr('data-index');
        tabSlider.slideTo(slideIndex);
        $('#tab-slider--{{ section.id }} .tabs--desktop .tab').removeClass('active');
        $(this).addClass('active');
      }
    });
  });
</script>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #tab-slider_simple--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

