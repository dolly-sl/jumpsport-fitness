<section
  class="sxs section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="heading-section--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  <div class="container container--sm align--{{ section.settings.align }}">
    <div
      class="sxs__section  d-flex align-center justify-between sxs__section--sm"
    >
      <div class="sxs__image">
        <img
          loading="lazy"
          src="{{ section.settings.image | img_url: '470x470' }}"
          srcset="{{ section.settings.image | img_url: '940x940' }} 2x"
          alt="{{ section.settings.image.alt | escape }}"
        >
      </div>
      <div class="sxs__info">
        {% render 'dynamic-heading',
          level: section.settings.heading_level,
          title: section.settings.title,
          classList: section.settings.heading_level_display
        %}
        {{ section.settings.copy }}
        {% if section.settings.btn_url != blank and section.settings.btn_copy != blank %}
          <div class="actions">
            <a href="{{ section.settings.btn_url }}" class="btn btn--solid">
              {{ section.settings.btn_copy }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #heading-section--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

