<section
  class="cta-heading section-block pad-top--{{  section.settings.padding_top }} pad-bottom--{{  section.settings.padding_bottom }} pad-top__mobile--{{  section.settings.padding_top-mobile }} pad-bottom__mobile--{{  section.settings.padding_bottom-mobile }} background--{{ section.settings.background }}"
  id="cta-heading--{{ section.id }}"
>
  {% render 'arch', color: section.settings.background %}
  {% unless section.settings.hide_bg == true %}
    <img src="{{ 'pattern-bg.png' | asset_img_url: 'master' }}" alt="" class="quote-slider__bg">
  {% endunless %}
  <div class="container">
    <div class="cta-heading__inner d-flex justify-center text-center">
      {% if section.settings.eyebrow != blank %}
        <span class="eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}
      {% render 'dynamic-heading',
        level: section.settings.heading_level,
        title: section.settings.title,
        classList: section.settings.heading_level_display
      %}
      {% if section.settings.copy != blank %}
        <div class="cta-heading__copy">
          <div class="copy-inner">
            {{ section.settings.copy }}
          </div>
        </div>
      {% endif %}
      {% if section.settings.btn_url != blank and section.settings.btn_copy != blank %}
        <div class="actions d-flex justify-center">
          <a href="{{ section.settings.btn_url }}" class="btn btn--solid btn--arrow btn--xl">
            {{ section.settings.btn_copy }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% if section.settings['padding_bottom-mobile'] == 'never-going-to-hit'
  or section.settings['padding_top-mobile'] == 'never-going-to-hit'
%}
  <style>
    @media(max-width: 768px) {
      #cta-heading--{{ section.id }} {
        padding-top: {{ section.settings.padding_top-mobile }}px !important;
        padding-bottom: {{ section.settings.padding_bottom-mobile }}px !important;
      }
    }
  </style>
{% endif %}

